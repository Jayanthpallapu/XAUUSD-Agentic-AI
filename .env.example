# System Port
PORT=8000

# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL=https://your-vercel-app.vercel.app

# LLM Configuration — Hermes 3 (Primary) + Groq (Failover)
# Get free OpenRouter key at: https://openrouter.ai (enables Hermes 3 405B model)
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here
GROQ_API_KEY=gsk_your_groq_api_key_here

# Supabase Database Configuration
SUPABASE_URL=https://your-supabase-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key-here

# Telegram Notification Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Market Data API Keys
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
FRED_API_KEY=your_fred_api_key_here
FMP_API_KEY=your_fmp_api_key_here
COINGECKO_API_KEY=your_coingecko_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# Runner Settings
RUN_INTERVAL_MINUTES=15
